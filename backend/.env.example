# MikroTik RouterOS API
MIKROTIK_HOST=192.168.88.1
MIKROTIK_PORT=8728
MIKROTIK_USER=admin
MIKROTIK_PASSWORD=sua_senha_aqui

# Hotspot profile configurado no MikroTik (em IP > Hotspot > Profiles)
HOTSPOT_PROFILE=default

# Tempo de sessão do usuário (em segundos). 0 = sem limite
SESSION_TIMEOUT=0

# Permite que CORS aceite requisições da página do hotspot (deixe * em dev)
ALLOWED_ORIGINS=*
